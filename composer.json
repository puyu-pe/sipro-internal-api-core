{
  "name": "puyu-pe/sipro-internal-api-core",
  "version": "0.1.0",
  "description": "Framework-agnostic core contracts, HMAC security utilities, and API response/error standards for SIPRO internal API.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "PuyuPe\\SiproInternalApiCore\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PuyuPe\\SiproInternalApiCore\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
